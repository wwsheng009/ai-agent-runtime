# Vite dev server
VITE_DEV_HOST=0.0.0.0
VITE_DEV_PORT=5193
VITE_DEV_ALLOWED_HOSTS=localhost,127.0.0.1
# 通过反向代理或自定义域名访问时可设置，例如 https://dev.example.com
VITE_DEV_PUBLIC_ORIGIN=
# 如需单独覆盖 HMR 连接参数，可按需填写
VITE_DEV_HMR_HOST=
VITE_DEV_HMR_PROTOCOL=
VITE_DEV_HMR_PORT=
VITE_DEV_HMR_CLIENT_PORT=
VITE_DEV_HMR_PATH=

# Runtime API
VITE_API_BASE_URL=
VITE_API_PROXY_PORT=8101
VITE_API_PROXY_TARGET=http://127.0.0.1:8101

# Optional runtime identity hints
# 留空时会基于 runtime base URL 自动推导 scope，并在浏览器 localStorage 中生成持久化 client id
VITE_RUNTIME_WORKSPACE_SCOPE=
# 如需让 /api/agent/chat 注入明确的 backend workspace_path，可在这里填写
VITE_RUNTIME_WORKSPACE_PATH=
